# Managed by Ansible (ingress-infra) — do not edit manually
# Ingress interface: dual-stack (IPv4 + IPv6)
# Egress/fabric: IPv6-only (see netplan-gre.yaml.j2 for tunnel config)
network:
  version: 2
  ethernets:
    {{ networking_egress_iface }}:
      dhcp4: true
      dhcp6: true
      accept-ra: true
      routes:
        - to: "{{ networking_mc_route_prefix }}"
          scope: link
