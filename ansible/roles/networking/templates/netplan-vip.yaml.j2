# Managed by Ansible (ingress-infra) — do not edit manually
# BGP VIPs on loopback — dual-stack (IPv4 and/or IPv6)
network:
  version: 2
  ethernets:
    lo:
      addresses:
{% if bgp_vip | length > 0 %}
        - "{{ bgp_vip }}/32"
{% endif %}
{% if bgp_vip6 | length > 0 %}
        - "{{ bgp_vip6 }}/128"
{% endif %}
