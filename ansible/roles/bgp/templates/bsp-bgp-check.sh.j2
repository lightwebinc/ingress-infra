#!/bin/sh
# BGP health-check for shard-proxy — dual-stack
# Managed by Ansible — do not edit manually
#
# Withdraws BGP routes (IPv4 and IPv6) if the proxy health endpoint is unhealthy.

# Path is configurable: /healthz (liveness, default — withdraw when the proxy is
# dead) or /readyz (readiness — withdraw at drain START so a hostNetwork anycast
# pod sheds traffic to its peers BEFORE it stops).
HEALTH_URL="http://127.0.0.1:{{ metrics_addr | regex_replace('^:', '') | default('9100') }}{{ bgp_health_path | default('/healthz') }}"

if curl -sf --max-time 3 "${HEALTH_URL}" > /dev/null 2>&1; then
{% if bgp_daemon == 'bird2' %}
{% if bgp_peer_ip | length > 0 %}
  birdc 'enable protocol upstream4' > /dev/null 2>&1 || true
{% endif %}
{% if bgp_peer_ip6 | length > 0 %}
  birdc 'enable protocol upstream6' > /dev/null 2>&1 || true
{% endif %}
{% else %}
{% if bgp_peer_ip | length > 0 %}
  vtysh -c "configure terminal" \
        -c "router bgp {{ bgp_local_as }}" \
        -c "no neighbor {{ bgp_peer_ip }} shutdown" > /dev/null 2>&1 || true
{% endif %}
{% if bgp_peer_ip6 | length > 0 %}
  vtysh -c "configure terminal" \
        -c "router bgp {{ bgp_local_as }}" \
        -c "no neighbor {{ bgp_peer_ip6 }} shutdown" > /dev/null 2>&1 || true
{% endif %}
{% endif %}
else
{% if bgp_daemon == 'bird2' %}
{% if bgp_peer_ip | length > 0 %}
  birdc 'disable protocol upstream4' > /dev/null 2>&1 || true
{% endif %}
{% if bgp_peer_ip6 | length > 0 %}
  birdc 'disable protocol upstream6' > /dev/null 2>&1 || true
{% endif %}
{% else %}
{% if bgp_peer_ip | length > 0 %}
  vtysh -c "configure terminal" \
        -c "router bgp {{ bgp_local_as }}" \
        -c "neighbor {{ bgp_peer_ip }} shutdown" > /dev/null 2>&1 || true
{% endif %}
{% if bgp_peer_ip6 | length > 0 %}
  vtysh -c "configure terminal" \
        -c "router bgp {{ bgp_local_as }}" \
        -c "neighbor {{ bgp_peer_ip6 }} shutdown" > /dev/null 2>&1 || true
{% endif %}
{% endif %}
fi
