# shard-proxy environment configuration
# Managed by Ansible — do not edit manually

LISTEN_ADDR={{ listen_addr }}
UDP_LISTEN_PORT={{ udp_listen_port }}
TCP_LISTEN_PORT={{ tcp_listen_port }}
EGRESS_PORT={{ egress_port }}
MULTICAST_IF={{ egress_iface if egress_iface is string else egress_iface | join(',') }}
SHARD_BITS={{ shard_bits }}
MC_SCOPE={{ mc_scope }}
MC_GROUP_ID={{ mc_group_id }}
NUM_WORKERS={{ num_workers }}
METRICS_ADDR={{ metrics_addr }}
OTLP_ENDPOINT={{ otlp_endpoint }}
OTLP_INTERVAL={{ otlp_interval }}
DRAIN_TIMEOUT={{ drain_timeout }}
DEBUG={{ 'true' if proxy_debug else 'false' }}
FRAG_MTU={{ frag_mtu | default(0) }}
TXID_DEDUP_LOCAL_CAP={{ txid_dedup_local_cap | default(1048576) }}
{% if txid_dedup_backend | default('') %}
TXID_DEDUP_BACKEND={{ txid_dedup_backend }}
{% endif %}
TXID_DEDUP_REDIS_ADDR={{ txid_dedup_redis_addr | default('') }}
{% if txid_dedup_aerospike_hosts | default('') %}
TXID_DEDUP_AEROSPIKE_HOSTS={{ txid_dedup_aerospike_hosts }}
TXID_DEDUP_AEROSPIKE_NAMESPACE={{ txid_dedup_aerospike_namespace | default('cache') }}
TXID_DEDUP_AEROSPIKE_SET={{ txid_dedup_aerospike_set | default('bsp') }}
{% endif %}
TXID_DEDUP_PREFIX={{ txid_dedup_prefix | default('bsp:tx:') }}
TXID_DEDUP_TTL={{ txid_dedup_ttl | default('10m') }}
