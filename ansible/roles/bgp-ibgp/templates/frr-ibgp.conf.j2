! FRR iBGP configuration for ingress-infra BGP
! Managed by Ansible — do not edit manually
! Role: upstream iBGP peer (same AS, advertises BGP prefix inward)
!
frr defaults traditional
log syslog informational
!
router bgp {{ bgp_local_as }}
 bgp router-id {{ bgp_router_id }}
{% for p in bgp_ibgp_peers %}
{% if p.peer_ip | default('') | length > 0 %}
 neighbor {{ p.peer_ip }} remote-as {{ bgp_local_as }}
 neighbor {{ p.peer_ip }} description {{ p.description | default('ibgp-peer-' ~ loop.index0) }}-v4
 neighbor {{ p.peer_ip }} timers {{ bgp_keepalive }} {{ bgp_hold_time }}
{% if bgp_vip | default('') | length > 0 %}
 neighbor {{ p.peer_ip }} update-source {{ bgp_vip }}
{% endif %}
{% if bgp_password | length > 0 %}
 neighbor {{ p.peer_ip }} password {{ bgp_password }}
{% endif %}
{% endif %}
{% if p.peer_ip6 | default('') | length > 0 %}
 neighbor {{ p.peer_ip6 }} remote-as {{ bgp_local_as }}
 neighbor {{ p.peer_ip6 }} description {{ p.description | default('ibgp-peer-' ~ loop.index0) }}-v6
 neighbor {{ p.peer_ip6 }} timers {{ bgp_keepalive }} {{ bgp_hold_time }}
{% if bgp_vip6 | default('') | length > 0 %}
 neighbor {{ p.peer_ip6 }} update-source {{ bgp_vip6 }}
{% endif %}
{% if bgp_password | length > 0 %}
 neighbor {{ p.peer_ip6 }} password {{ bgp_password }}
{% endif %}
{% endif %}
{% endfor %}
{% if bgp_prefix | length > 0 %}
 !
 address-family ipv4 unicast
{% for prefix in bgp_prefix %}
  network {{ prefix }}
{% endfor %}
{% for p in bgp_ibgp_peers %}
{% if p.peer_ip | default('') | length > 0 %}
  neighbor {{ p.peer_ip }} next-hop-self
  neighbor {{ p.peer_ip }} route-map EXPORT4 out
  neighbor {{ p.peer_ip }} route-map DENY in
{% endif %}
{% endfor %}
 exit-address-family
{% endif %}
{% if bgp_prefix6 | length > 0 %}
 !
 address-family ipv6 unicast
{% for prefix in bgp_prefix6 %}
  network {{ prefix }}
{% endfor %}
{% for p in bgp_ibgp_peers %}
{% if p.peer_ip6 | default('') | length > 0 %}
  neighbor {{ p.peer_ip6 }} next-hop-self
  neighbor {{ p.peer_ip6 }} route-map EXPORT6 out
  neighbor {{ p.peer_ip6 }} route-map DENY in
{% endif %}
{% endfor %}
 exit-address-family
{% endif %}
!
{% if bgp_prefix | length > 0 %}
{% for prefix in bgp_prefix %}
ip prefix-list BGP4 seq {{ (loop.index0 * 10) + 10 }} permit {{ prefix }}
{% endfor %}
!
route-map EXPORT4 permit 10
 match ip address prefix-list BGP4
!
{% endif %}
{% if bgp_prefix6 | length > 0 %}
{% for prefix in bgp_prefix6 %}
ipv6 prefix-list BGP6 seq {{ (loop.index0 * 10) + 10 }} permit {{ prefix }}
{% endfor %}
!
route-map EXPORT6 permit 10
 match ipv6 address prefix-list BGP6
!
{% endif %}
route-map DENY deny 10
!
