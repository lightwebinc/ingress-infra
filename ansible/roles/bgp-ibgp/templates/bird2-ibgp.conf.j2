# BIRD2 iBGP configuration for ingress-infra BGP
# Managed by Ansible — do not edit manually
# Role: upstream iBGP peer (same AS, advertises BGP prefix inward)

router id {{ bgp_router_id }};

protocol device {}

protocol direct {
  ipv4;
  ipv6;
}

protocol kernel {
  ipv4 {
    export all;
  };
  ipv6 {
    export all;
  };
}

{% if bgp_prefix | length > 0 %}
define BGP4_PFXS = [ {{ bgp_prefix | join(', ') }} ];
filter export_bgp4 {
  if net ~ BGP4_PFXS then accept;
  reject;
}

protocol static bgp4 {
  ipv4;
{% for prefix in bgp_prefix %}
  route {{ prefix }} blackhole;
{% endfor %}
}
{% endif %}

{% if bgp_prefix6 | length > 0 %}
define BGP6_PFXS = [ {{ bgp_prefix6 | join(', ') }} ];
filter export_bgp6 {
  if net ~ BGP6_PFXS then accept;
  reject;
}

protocol static bgp6 {
  ipv6;
{% for prefix in bgp_prefix6 %}
  route {{ prefix }} blackhole;
{% endfor %}
}
{% endif %}

filter accept_none { reject; }

{% for p in bgp_ibgp_peers %}
{% if p.peer_ip | default('') | length > 0 %}
protocol bgp ibgp_{{ loop.index0 }}_v4 {
  local as {{ bgp_local_as }};
  neighbor {{ p.peer_ip }} as {{ bgp_local_as }};
  hold time {{ bgp_hold_time }};
  keepalive time {{ bgp_keepalive }};
{% if bgp_password | length > 0 %}
  password "{{ bgp_password }}";
{% endif %}
  description "{{ p.description | default('ibgp-peer-' ~ loop.index0) }} (IPv4)";

  ipv4 {
    next hop self;
    import filter accept_none;
{% if bgp_prefix | length > 0 %}
    export filter export_bgp4;
{% else %}
    export filter accept_none;
{% endif %}
  };
}
{% endif %}
{% if p.peer_ip6 | default('') | length > 0 %}
protocol bgp ibgp_{{ loop.index0 }}_v6 {
  local as {{ bgp_local_as }};
  neighbor {{ p.peer_ip6 }} as {{ bgp_local_as }};
  hold time {{ bgp_hold_time }};
  keepalive time {{ bgp_keepalive }};
{% if bgp_password | length > 0 %}
  password "{{ bgp_password }}";
{% endif %}
  description "{{ p.description | default('ibgp-peer-' ~ loop.index0) }} (IPv6)";

  ipv6 {
    next hop self;
    import filter accept_none;
{% if bgp_prefix6 | length > 0 %}
    export filter export_bgp6;
{% else %}
    export filter accept_none;
{% endif %}
  };
}
{% endif %}
{% endfor %}
